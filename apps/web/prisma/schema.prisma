generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rol       Rol      @default(EMPLEADO)
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())
  animales  Animal[]
  tareas    Tarea[]

  @@map("usuarios")
}

model Potrero {
  id          Int      @id @default(autoincrement())
  nombre      String
  hectareas   Float?
  capacidad   Int?
  descripcion String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())
  animales    Animal[]

  @@map("potreros")
}

model Animal {
  id                  Int                  @id @default(autoincrement())
  codigo              String               @unique
  nombre              String?
  especie             Especie
  raza                String?
  sexo                Sexo
  color               String?
  numeroArete         String?
  fechaNac            DateTime?
  peso                Float?
  estado              EstadoAnimal         @default(ACTIVO)
  observaciones       String?
  potreroId           Int?
  potrero             Potrero?             @relation(fields: [potreroId], references: [id])
  padreId             Int?
  madreId             Int?
  creadoEn            DateTime             @default(now())
  actualizadoEn       DateTime             @updatedAt
  usuarioId           Int?
  usuario             Usuario?             @relation(fields: [usuarioId], references: [id])
  registros           RegistroSalud[]
  producciones        Produccion[]
  vacunaciones        Vacunacion[]
  eventosReproductivos EventoReproductivo[]
  pesajes             PesajeHistorial[]
  tareas              Tarea[]

  @@map("animales")
}

model PesajeHistorial {
  id            Int      @id @default(autoincrement())
  animalId      Int
  animal        Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  peso          Float
  fecha         DateTime @default(now())
  observaciones String?
  creadoEn      DateTime @default(now())

  @@map("pesajes_historial")
}

model RegistroSalud {
  id          Int      @id @default(autoincrement())
  animalId    Int
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  tipo        String
  descripcion String   @db.Text
  fecha       DateTime @default(now())
  veterinario String?
  costo       Float?
  creadoEn    DateTime @default(now())

  @@map("registros_salud")
}

model Vacunacion {
  id           Int       @id @default(autoincrement())
  animalId     Int
  animal       Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  vacuna       String
  dosis        String?
  lote         String?
  fecha        DateTime  @default(now())
  proximaDosis DateTime?
  veterinario  String?
  costo        Float?
  observaciones String?
  creadoEn     DateTime  @default(now())

  @@map("vacunaciones")
}

model EventoReproductivo {
  id            Int        @id @default(autoincrement())
  animalId      Int
  animal        Animal     @relation(fields: [animalId], references: [id], onDelete: Cascade)
  tipo          TipoEvento
  fecha         DateTime   @default(now())
  observaciones String?
  resultado     String?
  padreId       Int?
  costo         Float?
  creadoEn      DateTime   @default(now())

  @@map("eventos_reproductivos")
}

model Produccion {
  id       Int      @id @default(autoincrement())
  animalId Int
  animal   Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  tipo     String
  cantidad Float
  unidad   String
  fecha    DateTime @default(now())
  creadoEn DateTime @default(now())

  @@map("producciones")
}

model Tarea {
  id              Int         @id @default(autoincrement())
  titulo          String
  descripcion     String?
  fecha           DateTime    @default(now())
  fechaVencimiento DateTime?
  estado          EstadoTarea @default(PENDIENTE)
  prioridad       Prioridad   @default(MEDIA)
  asignadoA       String?
  animalId        Int?
  animal          Animal?     @relation(fields: [animalId], references: [id], onDelete: SetNull)
  usuarioId       Int?
  usuario         Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  creadoEn        DateTime    @default(now())

  @@map("tareas")
}

enum Rol {
  ADMIN
  EMPLEADO
}

enum Especie {
  BOVINO
  PORCINO
  OVINO
  CAPRINO
  EQUINO
  AVICOLA
  OTRO
}

enum Sexo {
  MACHO
  HEMBRA
}

enum EstadoAnimal {
  ACTIVO
  VENDIDO
  MUERTO
  TRANSFERIDO
}

enum TipoEvento {
  CELO
  MONTA
  INSEMINACION
  PRENEZ_CONFIRMADA
  PARTO
  ABORTO
  DESTETE
}

enum EstadoTarea {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}
